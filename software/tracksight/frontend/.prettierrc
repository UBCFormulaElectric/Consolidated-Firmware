{
  "$schema": "https://json.schemastore.org/prettierrc",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "printWidth": 1000,
  "tabWidth": 4,
  "bracketSpacing": true,
  "arrowParens": "always",
  "plugins": ["prettier-plugin-tailwindcss", "prettier-plugin-organize-imports"],
  "organizeImportsSkipDestructiveCodeActions": true
}
